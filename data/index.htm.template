    function uploadFirmware() {
      var fileInput = document.getElementById('firmwareFile');
      var file = fileInput.files[0];
      if (!file) { showToast('Please select a firmware file', 'error'); return; }
      if (!file.name.endsWith('.bin') && !file.name.endsWith('.bin.gz')) {
        showToast('Invalid file type. Use .bin or .bin.gz', 'error'); return;
      }
      if (file.size > 4194304) { showToast('File too large (max 4MB)', 'error'); return; }

      var btn = document.getElementById('firmwareBtn');
      btn.disabled = true;
      btn.style.opacity = '0.5';
      var progressDiv = document.getElementById('fwProgress');
      var progressBar = document.getElementById('fwProgressBar');
      progressDiv.style.display = 'block';

      var formData = new FormData();
      formData.append('firmware', file);

      var xhr = new XMLHttpRequest();
      xhr.open('POST', 'update?name=firmware', true);

      xhr.upload.onprogress = function(e) {
        if (e.lengthComputable) {
          var pct = Math.round((e.loaded / e.total) * 100);
          progressBar.style.width = pct + '%';
          progressBar.textContent = pct + '%';
        }
      };

      xhr.onload = function() {
        if (xhr.status === 200 && xhr.responseText.indexOf('Success') !== -1) {
          progressBar.style.width = '100%';
          progressBar.textContent = 'Flashed! Waiting for reboot...';
          progressBar.style.background = '#4caf50';
          showToast('Update successful! Waiting for device to reconnect...', 'success', 60000);
          waitForReconnect(60);
        } else {
          progressBar.style.background = '#f44336';
          progressBar.textContent = 'Failed';
          showToast('Update failed: ' + xhr.responseText, 'error', 5000);
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      };

      xhr.onerror = function() {
        progressBar.style.background = '#f44336';
        progressBar.textContent = 'Error';
        showToast('Upload failed - connection error', 'error', 5000);
        btn.disabled = false;
        btn.style.opacity = '1';
      };

      xhr.ontimeout = function() {
        progressBar.style.background = '#f44336';
        progressBar.textContent = 'Timeout';
        showToast('Upload timed out', 'error', 5000);
        btn.disabled = false;
        btn.style.opacity = '1';
      };

      xhr.timeout = 120000; // 2 minutes
      showToast('Uploading firmware...', 'pending', 60000);
      xhr.send(formData);
    }

    function waitForReconnect(maxSeconds) {
      var progressBar = document.getElementById('fwProgressBar');
      var elapsed = 0;
      var interval = setInterval(function() {
        elapsed++;
        var remaining = maxSeconds - elapsed;
        if (progressBar) progressBar.textContent = 'Reconnecting... ' + remaining + 's';
        // Try to reach the device
        fetch('/', { method: 'HEAD', cache: 'no-store' }).then(function(r) {
          if (r.ok) {
            clearInterval(interval);
            if (progressBar) progressBar.textContent = 'Reconnected!';
            showToast('Device is back online!', 'success', 3000);
            setTimeout(function() { location.reload(); }, 1500);
          }
        }).catch(function() {}); // ignore errors, keep waiting
        if (elapsed >= maxSeconds) {
          clearInterval(interval);
          if (progressBar) { progressBar.textContent = 'Timeout - try refreshing manually'; progressBar.style.background = '#ff9800'; }
          showToast('Device did not reconnect within ' + maxSeconds + 's', 'error', 5000);
          var btn = document.getElementById('firmwareBtn');
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      }, 1000);
    }

    function showToast(message, status = 'success', duration = 1800) {
      const toast = document.getElementById('toast');
      if (!toast) return;
      toast.textContent = message;
      toast.classList.remove('success', 'pending', 'error');
      toast.classList.add(status, 'show');
      if (toastTimer) clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('show'), duration);
    }

