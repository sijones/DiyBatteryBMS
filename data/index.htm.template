      // Handle WiFi scan results from WebSocket
      if(obj.hasOwnProperty('wifinetworks')) {
        PopulateWifiList(obj.wifinetworks);
      }

      if(obj.hasOwnProperty('Message')) alert(obj.Message);
      if(obj.hasOwnProperty('ERROR')) alert(obj.ERROR);
