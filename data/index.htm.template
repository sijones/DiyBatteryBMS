    function initWebSocket() {
      console.log('Trying to open a WebSocket connection...');
      websocket = new WebSocket(gateway);
      websocket.onopen = onOpen;
      websocket.onclose = onClose;
      websocket.onmessage = onMessage;
      websocket.onerror = onError;
    }

    function setConnStatus(connected) {
      var dot = document.getElementById('connDot');
      var txt = document.getElementById('connText');
      if (connected) { dot.classList.add('connected'); txt.textContent = 'Connected'; }
      else { dot.classList.remove('connected'); txt.textContent = 'Disconnected'; }
    }

    function onOpen(event) {
      console.log('WebSocket connection opened');
      setConnStatus(true);
    }

    function onError(event) {
      console.error('WebSocket error:', event);
    }

    function onClose(event) {
      console.log('WebSocket connection closed. Code:', event.code, 'Reason:', event.reason);
      setConnStatus(false);
      setTimeout(initWebSocket, 2000);
    }

    function onMessage(event) {
      const obj = JSON.parse(event.data);
      
      // Handle log messages
      if(obj.hasOwnProperty('log')) {
        addLogEntry(obj.log, obj.level || 'info');
        return;
      }
      
      // Log non-log messages only if verbose debugging needed
      // console.log(event.data);

      if(obj.hasOwnProperty('BMS') && obj.BMS) {
        ['chargevoltage','minchargecurr','adjuststep','smartinterval','overvoltage',
         'dischargevoltage','maxchargecurrent','maxdischargecurrent','batterycapacity',
         'lowsoclimit','highsoclimit','velooptime'].forEach(function(f) {
          if(obj[f] !== undefined) { document.getElementById(f).value=obj[f]; AckUpdate(f); }
        });
        if(obj.canbusenabled !== undefined) { document.getElementById('canbusenabled').checked=obj.canbusenabled; AckUpdate('canbusenabled'); }
      }

      if(obj.hasOwnProperty('RealTime') && obj.RealTime) {
        // Update battery SOC and visual indicator
        if(obj.hasOwnProperty('battsoc')) {
          const soc = obj.battsoc;

          // Update battery visual
          const batteryLevel = document.getElementById('batteryLevel');
          const batteryPercentage = document.getElementById('batteryPercentage');

          if(batteryLevel && batteryPercentage) {
            batteryLevel.style.width = soc + '%';
            batteryPercentage.innerHTML = soc + '%';

            // Update battery color based on level
            batteryLevel.className = 'battery-level';
            if(soc <= 20) {
              batteryLevel.classList.add('low');
            } else if(soc <= 50) {
              batteryLevel.classList.add('medium');
            } else {
              batteryLevel.classList.add('high');
            }
          }

          // Show warning if SOC is low
          updateWarnings(soc, obj.chargeenabled, obj.dischargeenabled);
        }

        if(obj.hasOwnProperty('battvoltage')) document.getElementById('battvoltage').innerHTML=(obj.battvoltage*0.01).toFixed(1);

        // Update battery current and power flow indicator
        if(obj.hasOwnProperty('battcurrent')) {
          const current = obj.battcurrent * 0.1;
          const battCurrentElem = document.getElementById('battcurrent');
          if(battCurrentElem) {
            battCurrentElem.innerHTML = current.toFixed(1);
          }

          // Update battery wave animation and power flow indicator
          const batteryWave = document.getElementById('batteryWave');
          const flowText = document.getElementById('powerFlowText');

          if(batteryWave && flowText) {
            // Remove all classes first
            batteryWave.className = 'battery-wave';
            flowText.className = 'flow-text';

            if(obj.forcecharge) {
              batteryWave.classList.add('active', 'charging');
              flowText.classList.add('charging');
              flowText.innerHTML = '&#9889; Force Charging';
              flowText.style.color = '#f44336';
            } else if(current > 0.5) {
              batteryWave.classList.add('active', 'charging');
              flowText.classList.add('charging');
              flowText.innerHTML = '&#9650; Charging';
              flowText.style.color = '#4caf50';
            } else if(current < -0.5) {
              batteryWave.classList.add('active', 'discharging');
              flowText.classList.add('discharging');
              flowText.innerHTML = '&#9660; Discharging';
              flowText.style.color = '#ff9800';
            } else {
              flowText.innerHTML = 'Idle';
              flowText.style.color = '#667eea';
            }
          }
        }

        if(obj.hasOwnProperty('battpower')) {
          var powerElem = document.getElementById('battpower');
          if(powerElem) powerElem.innerHTML = Math.abs(obj.battpower);
        }

        if(obj.hasOwnProperty('timetogo')) {
          var ttgElem = document.getElementById('timetogo');
          if(ttgElem) {
            var ttg = obj.timetogo;
            if(ttg < 0) { ttgElem.innerHTML = '--'; }
            else if(ttg >= 1440) { ttgElem.innerHTML = (ttg / 1440).toFixed(1) + 'd'; }
            else if(ttg >= 60) { ttgElem.innerHTML = Math.floor(ttg/60) + 'h ' + (ttg%60) + 'm'; }
            else { ttgElem.innerHTML = ttg + 'm'; }
          }
        }

        if(obj.hasOwnProperty('batttemp')) {
          var tempElem = document.getElementById('batttemp');
          if(tempElem) tempElem.innerHTML = obj.batttemp;
        }
        if(obj.hasOwnProperty('mqttinvertertemp')) {
          var e = document.getElementById('mqttinvertertemp');
          if(e) e.innerHTML = obj.mqttinvertertemp == -127 ? '--' : obj.mqttinvertertemp;
        }
        if(obj.hasOwnProperty('fanpwm')) {
          var e = document.getElementById('fanpwm');
          if(e) e.innerHTML = obj.fanpwm;
        }

        if(obj.hasOwnProperty('showtempdashboard')) {
          var tempRow = document.getElementById('tempRow');
          if(tempRow) tempRow.style.display = obj.showtempdashboard ? '' : 'none';
        }

        if(obj.hasOwnProperty('chargeadjust')) {
          var adjElem = document.getElementById('chargeadjust');
          if(adjElem) adjElem.innerHTML = (obj.chargeadjust * 0.001).toFixed(0);
        }

        if(obj.hasOwnProperty('chargecurrent')) document.getElementById('chargecurrent').innerHTML=(obj.chargecurrent*0.001).toFixed(0);
        if(obj.hasOwnProperty('dischargecurrent')) document.getElementById('dischargecurrent').innerHTML=(obj.dischargecurrent*0.001).toFixed(0);

        // Update Charge/Discharge enabled status with color coding
        if(obj.hasOwnProperty('chargeenabled')) {
          chargeEnabled = obj.chargeenabled;  // Track state for toggle
          let chargeStatus = document.getElementById('chargeenabledStatus');
          chargeStatus.innerHTML = obj.chargeenabled ? 'ON' : 'OFF';
          chargeStatus.style.color = obj.chargeenabled ? '#4caf50' : '#f44336';
        }
        if(obj.hasOwnProperty('dischargeenabled')) {
          dischargeEnabled = obj.dischargeenabled;  // Track state for toggle
          let dischargeStatus = document.getElementById('dischargeenabledStatus');
          dischargeStatus.innerHTML = obj.dischargeenabled ? 'ON' : 'OFF';
          dischargeStatus.style.color = obj.dischargeenabled ? '#4caf50' : '#f44336';
        }

        if(obj.hasOwnProperty('chargephase')) {
          let phaseElem = document.getElementById('chargephaseStatus');
          if(phaseElem) {
            phaseElem.innerHTML = obj.chargephase;
            if(obj.chargephase === 'Bulk') phaseElem.style.color = '#4caf50';
            else if(obj.chargephase === 'Absorption') phaseElem.style.color = '#ff9800';
            else if(obj.chargephase === 'Complete') phaseElem.style.color = '#2196f3';
            else phaseElem.style.color = '#667eea';
          }
        }

        // Update last update timestamp
        const lastUpdateElem = document.getElementById('lastUpdate');
        if(lastUpdateElem) {
          const now = new Date().toLocaleTimeString();
          lastUpdateElem.textContent = now;
        }
      }

      ['soctrickenabled','requestflagsenabled','never100soc','autocharge'].forEach(function(f) {
        if(obj[f] !== undefined) { document.getElementById(f).checked=obj[f]; AckUpdate(f); }
      });
      if(obj.hasOwnProperty('wifissid')) { 
        // Save the SSID as the current saved network
        savedWifiSSID = obj.wifissid;
        console.log("Updated saved WiFi SSID: " + savedWifiSSID);
        // Set the selected SSID in dropdown
        var select = document.getElementById('wifissid');
        select.value = obj.wifissid;
        // If dropdown is empty or doesn't have this SSID option, create it
        if(select.value !== obj.wifissid) {
          var el = document.createElement('option');
          el.textContent = obj.wifissid;
          el.value = obj.wifissid;
          el.selected = true;
          select.appendChild(el);
        }
        AckUpdate('wifissid');
      }
      ['wifipass','wifihostname','victronrxpin','victrontxpin',
       'mqttport','mqttserverip','mqttclientid','mqtttopic','mqttuser','mqttpass',
       'slowchargesoc1','slowchargesoc2','slowchargesoc1div','slowchargesoc2div',
       'tailduration','maxabsorptiontime','rechargesoc',
       'chargehightemp','chargelowtemp','dischargehightemp','dischargelowtemp',
       'mqttbatttopic','mqttinvtopic','fanofftemp','fanfulltemp',
       'ntpserver'].forEach(function(f) {
        if(obj[f] !== undefined) { document.getElementById(f).value=obj[f]; AckUpdate(f); }
      });
      {{CAN_FIELD_HANDLERS}}
      if(obj.tailcurrent !== undefined) { document.getElementById('tailcurrent').value=(obj.tailcurrent*0.001).toFixed(1); AckUpdate('tailcurrent'); }
      if(obj.rechargevoltageoffset !== undefined) { document.getElementById('rechargevoltageoffset').value=(obj.rechargevoltageoffset*0.001).toFixed(1); AckUpdate('rechargevoltageoffset'); }
      if(obj.tempprotection !== undefined) { document.getElementById('tempprotection').checked=obj.tempprotection; AckUpdate('tempprotection'); toggleTempConfig(); }
      if(obj.showtempdashboard !== undefined) { document.getElementById('showtempdashboard').checked=obj.showtempdashboard; AckUpdate('showtempdashboard'); }
      if(obj.batttempsrc !== undefined) { document.getElementById('batttempsrc').value=obj.batttempsrc; AckUpdate('batttempsrc'); toggleMqttTempTopics(); }
      if(obj.fantempsrc !== undefined) { document.getElementById('fantempsrc').value=obj.fantempsrc; AckUpdate('fantempsrc'); toggleMqttTempTopics(); }
      if(obj.lcdenabled !== undefined) { document.getElementById('lcdenabled').checked=obj.lcdenabled; AckUpdate('lcdenabled'); }
      {{FAN_PIN_HANDLER}}

      var devFields = {modelstring:'devModel',fwversion:'devFW',serialnumber:'devSerial',pidstring:'devPID'};
      for(var k in devFields) { if(obj[k] !== undefined) { var e=document.getElementById(devFields[k]); if(e) e.innerHTML=obj[k]||'--'; } }
      if(obj.hasOwnProperty('freeheap') && obj.hasOwnProperty('totalheap')) {
        var e=document.getElementById('heapInfo');
        if(e) e.innerHTML=(obj.freeheap/1024).toFixed(0) + 'KB / ' + (obj.totalheap/1024).toFixed(0) + 'KB';
      }
      if(obj.hasOwnProperty('cantotalfails')) {
        var e=document.getElementById('canFailInfo');
